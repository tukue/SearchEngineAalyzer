{
  "version": 2,
  "installCommand": "npm install --ignore-scripts --no-audit --no-fund",
  "buildCommand": "npm run build:client",
  "outputDirectory": "dist/public",
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
