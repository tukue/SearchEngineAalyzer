{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "builds": [
    { "src": "api/index.ts", "use": "@vercel/node@3.2.29" },
    { "src": "dist/client/**", "use": "@vercel/static@1.0.0" },
    { "src": "public/deploy-home.html", "use": "@vercel/static@1.0.0" }
  ],
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/deploy-home", "dest": "/deploy-home.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
