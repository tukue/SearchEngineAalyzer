{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "cleanUrls": true,
  "trailingSlash": false,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node@3.0.0",
      "config": {
        "includeFiles": ["dist/server/**"]
      }
    },
    {
      "src": "dist/client/**/*",
      "use": "@vercel/static@1.0.0"
    }
  ],
  "functions": {
    "api/index.ts": {
      "runtime": "nodejs20.x"
    }
  },
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/deploy-home", "dest": "/dist/client/deploy-home.html" },
    { "src": "/(.*)", "dest": "/dist/client/$1" },
    { "src": "/.*", "dest": "/dist/client/index.html" },
    { "src": "/", "dest": "/dist/client/index.html" }
  ]
}
