{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/deploy-home", "dest": "/deploy-home.html" },
    { "src": "/(.*)", "dest": "/$1" },
    { "src": "/.*", "dest": "/index.html" },
    { "src": "/", "dest": "/index.html" }
  ]
}
