{
  "version": 2,
  "framework": null,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/**": {
      "runtime": "nodejs20.x"
    }
  },
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/deploy-home", "dest": "/deploy-home.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
