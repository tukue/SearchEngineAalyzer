# Keep essential source available to Vercel builds
# (do NOT ignore client/, server/, shared/, vite.config.ts, etc.)

# Environment and Vercel metadata
.env*
.vercel/

# Dependencies and caches
node_modules/
.pnpm-store/
.npm/

# Build artifacts
coverage/
dist/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Tests and local-only tooling
__tests__/
**/*.test.*
**/*.spec.*
test/
tests/

# Editor/OS noise
.DS_Store
.vscode/
.idea/
