{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": "..",
    "paths": {
      "@/*": ["./client/src/*"],
      "@shared/*": ["./shared/*"]
    },
    "types": ["next", "next/types/global"]
  },
  "include": [
    "next-env.d.ts",
    "app/**/*",
    "../client/src/**/*",
    "../shared/**/*"
  ],
  "exclude": ["node_modules"]
}
