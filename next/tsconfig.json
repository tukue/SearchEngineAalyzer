{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@shared/*": ["./shared/*"],
      "@server/*": ["./server/*"]
    },
    "types": ["node", "next", "next/image-types/global"],
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
    "include": [
      "next-env.d.ts",
      "app/**/*",
      ".next/types/**/*.ts",
      "lib/**/*",
      "hooks/**/*",
      "components/**/*",
      "shared/**/*",
      "server/**/*"
    ]
  }
