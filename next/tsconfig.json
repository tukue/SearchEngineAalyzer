{
  "extends": "next/tsconfig",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./app/*", "./components/*", "../client/src/*"],
      "@shared/*": ["../shared/*"]
    }
  },
  "include": [
    "next-env.d.ts",
    "app/**/*",
    "components/**/*",
    "pages/**/*",
    "../client/src/**/*",
    "../shared/**/*"
  ],
  "exclude": ["node_modules"]
}
