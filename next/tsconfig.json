{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*", "../client/src/*"],
      "@client/*": ["../client/src/*"],
      "@shared/*": ["../shared/*"],
      "@server/*": ["./server/*"]
    },
    "types": ["node", "next", "next/image-types/global", "react", "react-dom"],
    "typeRoots": ["../node_modules/@types"],
    "allowJs": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "app/**/*",
    ".next/types/**/*.ts",
    "lib/**/*",
    "hooks/**/*",
    "components/**/*",
    "../shared/**/*",
    "server/**/*",
    "../client/src/**/*",
  ]
}
