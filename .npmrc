registry=https://registry.npmjs.org/
# Authentication is optional; leave NPM_TOKEN unset for public installs to avoid 403s in locked-down environments.
# If you need private packages, set NPM_TOKEN in CI/locally and npm will automatically use it without requiring always-auth.
# Explicitly disable proxies that may be injected by the environment; they can return 403s when egress is blocked.
proxy=false
https-proxy=false
noproxy=*
