registry=https://registry.npmjs.org/
# Authentication: set NPM_TOKEN in CI/locally to access private packages. Leave it unset for public installs.
//registry.npmjs.org/:_authToken=${NPM_TOKEN}
# Do not force authentication for public packages to keep proxy-free installs working; when NPM_TOKEN is set it will still be used.
always-auth=false
# Explicitly disable proxies that may be injected by the environment; they can return 403s when egress is blocked.
proxy=false
https-proxy=false
noproxy=*
