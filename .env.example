# Database
DATABASE_URL=postgresql://user:password@localhost:5432/webaudit

# Feature Flags for Reports
EXPORTS_ENABLED=true
PDF_EXPORTS=true
HTML_EXPORTS=true

# Export Storage (for production)
EXPORT_STORAGE_BUCKET=webaudit-exports
EXPORT_STORAGE_REGION=us-east-1
EXPORT_URL_EXPIRY_HOURS=24

# Server
PORT=5000
NODE_ENV=development