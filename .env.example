# Server configuration
PORT=5000
NODE_ENV=development

# API authentication tokens (comma-separated for multiple tokens)
API_AUTH_TOKEN=dev-token
API_AUTH_TOKENS=
API_TENANT_ID=1
API_USER_ID=dev-user
API_USER_ROLE=owner

# Database (optional; leave blank for in-memory storage)
DATABASE_URL=

# Test-only token override
TEST_API_TOKEN=test-token

# Vite dev server configuration
VITE_DEV_PORT=5173
VITE_API_PROXY_TARGET=http://localhost:5000

# Frontend auth token (required for API calls in dev)
VITE_API_TOKEN=dev-token
